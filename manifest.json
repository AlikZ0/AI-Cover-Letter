{
  "manifest_version": 3,
  "name": "AI Cover Letter Generator",
  "version": "1.0.0",
  "description": "Analyze job vacancies and generate personalized cover letters using AI",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.linkedin.com/*/jobs/*",
        "*://*.hh.ru/vacancy/*",
        "*://*.hh.kz/vacancy/*",
        "*://*.indeed.com/viewjob*",
        "*://*.indeed.com/*/viewjob*",
        "*://*.glassdoor.com/job-listing/*",
        "*://*.glassdoor.com/Job/*"
      ],
      "js": [
        "utils/parsers.js",
        "utils/language-detector.js",
        "utils/storage.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "settings/settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
